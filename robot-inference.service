[Unit]
Description=Robot Camera Inference Dashboard
After=network.target

[Service]
Type=simple
User=drone
WorkingDirectory=/home/drone/robot_inference
EnvironmentFile=/home/drone/robot_inference/.env
ExecStart=/home/drone/robot_inference/.venv/bin/python main.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
