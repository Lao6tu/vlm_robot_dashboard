# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Camera ────────────────────────────────────────────────────────────────────
# Full sensor resolution used as the capture mode (--mode) so the entire FOV
# is captured; rpicam-vid then downscales to OUTPUT_WIDTHxOUTPUT_HEIGHT.
# Set to 0 to let rpicam-vid choose automatically (may crop the FOV).
SENSOR_WIDTH=4656
SENSOR_HEIGHT=3496
OUTPUT_WIDTH=960
OUTPUT_HEIGHT=720
CAMERA_FRAMERATE=30
MJPEG_FPS=30

# ── Snapshot worker ───────────────────────────────────────────────────────────
SNAPSHOT_INTERVAL_SEC=1.0
SNAPSHOT_BUFFER_SIZE=10

# ── Inference scheduler (OpenAI-compatible) ───────────────────────────────────
# Base URL of the OpenAI-compatible VLM server (no trailing slash)
# Endpoint called: {INFERENCE_API_URL}/v1/chat/completions
INFERENCE_API_URL=http://100.122.141.97:8080

# API key — use "none" or any placeholder if the server has no auth
INFERENCE_API_KEY=none

# Model name as recognised by the server (e.g. llava, llava-1.6, qwen-vl)
INFERENCE_MODEL=qwen_finetune

# System / user prompt sent with every inference request
INFERENCE_PROMPT='You are a navigation risk assessment agent for an indoor mobile robot.
Task
Identify potential hazards on the current moving path and the free space width strictly in cm ahead from two consecutive frames.
Determine whether the robot can pass safely and suggest safe action from reasoning.
Decision rules:
- If free_space is too narrow or there are clear hazards / obstacles --> NO-GO
- If free_space is limited or there are potential hazards --> CAUTION
- If free_space is large and no major hazards --> GO
- Structural hazards (e.g., drop_off_or_hole, get_stuck) and restricted area will directly result in NO-GO.
Output format (JSON):
{
	"status": {
		"cat": "GO | CAUTION | NO-GO",
		"free_space": number or null
	},
	"action_advice": "next action",
	"reason": "reason to the action advice"
}'

# How often to fire inference (seconds)
INFERENCE_INTERVAL_SEC=3

# How many buffered frames to include per request
INFERENCE_FRAMES=2

# HTTP timeout for the inference API call (seconds)
INFERENCE_TIMEOUT_SEC=30
