# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Camera ────────────────────────────────────────────────────────────────────
# Full sensor resolution used as the capture mode (--mode) so the entire FOV
# is captured; rpicam-vid then downscales to OUTPUT_WIDTHxOUTPUT_HEIGHT.
# Set to 0 to let rpicam-vid choose automatically (may crop the FOV).
SENSOR_WIDTH=4656
SENSOR_HEIGHT=3496
OUTPUT_WIDTH=1440
OUTPUT_HEIGHT=1080
CAMERA_FRAMERATE=30
MJPEG_FPS=30

# ── Snapshot worker ───────────────────────────────────────────────────────────
SNAPSHOT_INTERVAL_SEC=0.5
SNAPSHOT_BUFFER_SIZE=5

# ── Inference scheduler (OpenAI-compatible) ───────────────────────────────────
# Base URL of the OpenAI-compatible VLM server (no trailing slash)
# Endpoint called: {INFERENCE_API_URL}/v1/chat/completions
INFERENCE_API_URL=http://100.122.141.97:8080
# INFERENCE_API_URL=http://10.42.0.244:8080

# API key — use "none" or any placeholder if the server has no auth
INFERENCE_API_KEY=none

# Model name as recognised by the server (e.g. llava, llava-1.6, qwen-vl)
INFERENCE_MODEL=qwen_finetune

# System / user prompt sent with every inference request
INFERENCE_PROMPT_FILE=prompts/navigation_prompt.txt

# How often to fire inference (seconds)
INFERENCE_INTERVAL_SEC=0.8

# How many buffered frames to include per request
INFERENCE_FRAMES=1

# HTTP timeout for the inference API call (seconds)
INFERENCE_TIMEOUT_SEC=30

# ── Live YOLO detection overlay ──────────────────────────────────────────────
LIVE_DETECTION_ENABLED=0
YOLO_MODEL_PATH=yolo26n_ncnn_model
YOLO_PREFER_NCNN=1
YOLO_CONF=0.35
YOLO_IOU=0.45
YOLO_INFER_EVERY_N=2
YOLO_IMGSZ=640
